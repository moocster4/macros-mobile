# iOS Simulator can reach the host machine's localhost directly.
# For a physical device via Expo Go, use your machine's LAN IP instead, e.g. http://192.168.1.23:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# Google Sign-In — create an "iOS" OAuth client in the SAME Google Cloud project
# as the web app's client (bundle ID: com.macros.app). The Google button is
# hidden until this is set.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
